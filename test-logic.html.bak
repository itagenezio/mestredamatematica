<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teste de Lógica - Mestre da Matemática</title>
    <style>
        body { font-family: sans-serif; background: #f0f2f5; padding: 20px; }
        .card { background: white; border-radius: 12px; padding: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); max-width: 600px; margin: auto; }
        h1 { color: #4338ca; text-align: center; }
        .problem { border-left: 4px solid #4338ca; padding: 10px; margin: 10px 0; background: #eef2ff; display: flex; justify-content: space-between; align-items: center; }
        .ans { font-weight: bold; color: #10b981; }
        button { background: #4338ca; color: white; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; width: 100%; font-size: 16px; margin-top: 10px; }
        .type { font-size: 12px; color: #6b7280; text-transform: uppercase; }
    </style>
</head>
<body>
    <div class="card">
        <h1>Teste de Lógica: 9º Ano</h1>
        <div id="output"></div>
        <button onclick="generate()">Gerar Novas Questões</button>
    </div>

    <script>
        const getRandomNumber = (min, max) => Math.floor(Math.random() * (max - min + 1)) + min;

        const generateProblem = () => {
            const types = ['arithmetic', 'power', 'sqrt', 'eq'];
            const type = types[Math.floor(Math.random() * types.length)];
            
            let problem = '';
            let answer = 0;

            switch(type) {
                case 'arithmetic':
                    const n1 = getRandomNumber(20, 100);
                    const n2 = getRandomNumber(20, 100);
                    problem = `${n1} + ${n2} = ?`;
                    answer = n1 + n2;
                    break;
                case 'power':
                    const base = getRandomNumber(2, 10);
                    const exp = (base > 5) ? 2 : 3;
                    problem = `${base}${exp === 2 ? '²' : '³'} = ?`;
                    answer = Math.pow(base, exp);
                    break;
                case 'sqrt':
                    const root = getRandomNumber(2, 15);
                    const num = root * root;
                    problem = `√${num} = ?`;
                    answer = root;
                    break;
                case 'eq':
                    const a = getRandomNumber(2, 8);
                    const xValue = getRandomNumber(1, 10);
                    const b = getRandomNumber(-10, 20);
                    const c = a * xValue + b;
                    problem = `${a}x ${b >= 0 ? '+' : '-'} ${Math.abs(b)} = ${c}`;
                    answer = xValue;
                    break;
            }

            return { problem, answer, type };
        };

        const generate = () => {
            const out = document.getElementById('output');
            out.innerHTML = '';
            for(let i = 0; i < 5; i++) {
                const p = generateProblem();
                out.innerHTML += `
                    <div class="problem">
                        <div>
                            <span class="type">${p.type}</span><br>
                            <strong>${p.problem}</strong>
                        </div>
                        <span class="ans">${p.answer}</span>
                    </div>
                `;
            }
        };

        generate();
    </script>
</body>
</html>
